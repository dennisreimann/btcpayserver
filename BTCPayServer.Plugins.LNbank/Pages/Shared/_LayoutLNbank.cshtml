@{
    Layout = "_Layout";
}

@section PageHeadContent {
    <link href="/Resources/css/lnbank.css" rel="stylesheet" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", false)
}

@section PageFootContent {
    <script src="/Resources/lib/signalr/dist/browser/signalr.js" asp-append-version="true"></script>
    <script src="/Resources/js/lnbank.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", false)
}

<section>
    <div class="container">
        @RenderBody()
    </div>
</section>
